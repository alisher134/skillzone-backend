model User {
    id String @id @default(cuid())
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    email String @unique
    username String
    password String

    avatarPath String?

    role UserRole @default(USER)

    @@map("user")
}

enum UserRole{
    ADMIN
    USER
}